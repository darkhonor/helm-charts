{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "description": "Automerge minor/patch Helm dependency updates",
      "matchManagers": ["helmv3"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Automerge minor/patch Docker image tag updates",
      "matchManagers": ["helm-values"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "SearXNG uses date-based tags (YYYY.M.D-commithash)",
      "matchPackageNames": ["ghcr.io/searxng/searxng"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})-[a-f0-9]+$"
    },
    {
      "description": "Require manual review for major version bumps",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    }
  ],
  "addLabels": ["renovate", "{{depName}}"],
  "enabledManagers": ["helmv3", "helm-values"],
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
